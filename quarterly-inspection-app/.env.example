PORT=3000

# monday.com API
MONDAY_API_TOKEN=your_monday_api_token
MONDAY_API_URL=https://api.monday.com/v2

# Board IDs
MONDAY_INVENTORY_BOARD_ID=1234567890
MONDAY_QUARTERLY_BOARD_ID=1234567891
MONDAY_DAILY_BOARD_ID=1234567892

# Optional if you want new rows in a specific group
MONDAY_QUARTERLY_GROUP_ID=
MONDAY_DAILY_GROUP_ID=

# Inventory board column IDs (required for loading equipment details)
MONDAY_INVENTORY_EQUIPMENT_ID_COLUMN_ID=
MONDAY_INVENTORY_MAKE_COLUMN_ID=
MONDAY_INVENTORY_MODEL_COLUMN_ID=
MONDAY_INVENTORY_TYPE_COLUMN_ID=

# Quarterly board column IDs (required for submit)
MONDAY_QUARTERLY_MODEL_COLUMN_ID=
MONDAY_QUARTERLY_CHECK_DATE_COLUMN_ID=
MONDAY_QUARTERLY_PASS_FAIL_COLUMN_ID=
MONDAY_QUARTERLY_COMMENTS_COLUMN_ID=
MONDAY_QUARTERLY_NEXT_CHECK_DATE_COLUMN_ID=

# Optional labels and schedule behavior
MONDAY_PASS_LABEL=Pass
MONDAY_FAIL_LABEL=Fail
MONDAY_QUARTERLY_INTERVAL_MONTHS=3

# Daily board column IDs (optional but recommended for rich daily records)
MONDAY_DAILY_SERIAL_COLUMN_ID=
MONDAY_DAILY_EQUIPMENT_ID_COLUMN_ID=
MONDAY_DAILY_MAKE_COLUMN_ID=
MONDAY_DAILY_MODEL_COLUMN_ID=
MONDAY_DAILY_TYPE_COLUMN_ID=
MONDAY_DAILY_OPERATOR_NAME_COLUMN_ID=
MONDAY_DAILY_OPERATOR_ID_COLUMN_ID=
MONDAY_DAILY_CHECK_DATE_COLUMN_ID=
MONDAY_DAILY_CHECK_TIME_COLUMN_ID=
MONDAY_DAILY_OVERALL_RESULT_COLUMN_ID=
MONDAY_DAILY_FAILED_COUNT_COLUMN_ID=
MONDAY_DAILY_CHECKLIST_DETAILS_COLUMN_ID=
MONDAY_DAILY_GENERAL_COMMENTS_COLUMN_ID=

# Daily checklist per-item Pass/Fail status column IDs (Status columns)
MONDAY_DAILY_CHECK_VISUAL_GENERAL_CONDITION_COLUMN_ID=
MONDAY_DAILY_CHECK_VISUAL_BROKEN_CRACKED_OR_LOOSE_PARTS_COLUMN_ID=
MONDAY_DAILY_CHECK_VISUAL_OVERHEAD_GUARD_OBSTRUCTIONS_COLUMN_ID=
MONDAY_DAILY_CHECK_VISUAL_FIRE_EXTINGUISHER_PRESENT_CHARGED_COLUMN_ID=
MONDAY_DAILY_CHECK_VISUAL_SIGNAGE_CAPACITY_PLATE_COLUMN_ID=
MONDAY_DAILY_CHECK_VISUAL_WHEELS_TIRES_CONDITION_COLUMN_ID=
MONDAY_DAILY_CHECK_VISUAL_FORKS_BACKREST_MAST_CHAINS_ROLLERS_COLUMN_ID=
MONDAY_DAILY_CHECK_VISUAL_CHAIN_ANCHOR_PINS_COLUMN_ID=
MONDAY_DAILY_CHECK_VISUAL_FLUID_LEAKS_GROUND_COLUMN_ID=
MONDAY_DAILY_CHECK_VISUAL_HOSES_SECURE_NO_LEAKS_COLUMN_ID=
MONDAY_DAILY_CHECK_VISUAL_AIR_FILTER_CLEANLINESS_COLUMN_ID=
MONDAY_DAILY_CHECK_VISUAL_BATTERY_CONNECTIONS_COLUMN_ID=
MONDAY_DAILY_CHECK_OPERATIONAL_ENGINE_NOT_ROUGH_COLUMN_ID=
MONDAY_DAILY_CHECK_OPERATIONAL_GAUGES_HORN_COLUMN_ID=
MONDAY_DAILY_CHECK_OPERATIONAL_LIGHTS_HEAD_WARNING_COLUMN_ID=
MONDAY_DAILY_CHECK_OPERATIONAL_PLUGGING_FORWARD_REVERSE_COLUMN_ID=
MONDAY_DAILY_CHECK_OPERATIONAL_STEERING_COLUMN_ID=
MONDAY_DAILY_CHECK_OPERATIONAL_FORKS_MOTION_HYDRAULIC_COLUMN_ID=
