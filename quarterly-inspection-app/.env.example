PORT=3000

# monday.com API
MONDAY_API_TOKEN=your_monday_api_token
MONDAY_API_URL=https://api.monday.com/v2

# Board IDs
MONDAY_INVENTORY_BOARD_ID=1234567890
MONDAY_QUARTERLY_BOARD_ID=1234567891

# Optional if you want new rows in a specific group
MONDAY_QUARTERLY_GROUP_ID=

# Inventory board column IDs (required for loading equipment details)
MONDAY_INVENTORY_EQUIPMENT_ID_COLUMN_ID=
MONDAY_INVENTORY_MAKE_COLUMN_ID=
MONDAY_INVENTORY_MODEL_COLUMN_ID=
MONDAY_INVENTORY_TYPE_COLUMN_ID=

# Quarterly board column IDs (required for submit)
MONDAY_QUARTERLY_MODEL_COLUMN_ID=
MONDAY_QUARTERLY_CHECK_DATE_COLUMN_ID=
MONDAY_QUARTERLY_PASS_FAIL_COLUMN_ID=
MONDAY_QUARTERLY_COMMENTS_COLUMN_ID=
MONDAY_QUARTERLY_NEXT_CHECK_DATE_COLUMN_ID=

# Optional labels and schedule behavior
MONDAY_PASS_LABEL=Pass
MONDAY_FAIL_LABEL=Fail
MONDAY_QUARTERLY_INTERVAL_MONTHS=3
